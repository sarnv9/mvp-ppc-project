# ------------------------------------------------------------------------------
# PPC ADS AI ADVISOR - ENVIRONMENT VARIABLES TEMPLATE
# ------------------------------------------------------------------------------
# Instructions: Duplicate this file, rename it to '.env', and replace the 
# placeholders with your local database credentials and OpenAI API keys.
# ------------------------------------------------------------------------------

# Database Connections (PostgreSQL)
# Format: postgresql://username:password@localhost:5432/database_name

# Write/Modify access for ETL and data harmonization processes
ADMIN_DATABASE_URL=postgresql://your_postgres_user:your_postgres_password@localhost:5432/your_database_name

# Read-only access configuration for security guardrails in the SQL Agent
READ_ONLY_DATABASE_URL=postgresql://your_readonly_user:your_readonly_password@localhost:5432/your_database_name

# OpenAI API Configuration
# Your secret API key starting with 'sk-...' used by the LangChain agent
OPENAI_API_KEY=your_openai_api_key_here

# API Layer Configuration
# The local URL where FastAPI backend will run (Default: http://127.0.0.1:8000)
API_URL=http://127.0.0.1:8000